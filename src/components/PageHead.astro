---
import ThemeConfig from './ThemeConfig.astro';
import '../styles/tailwind.css';

interface Props {
  base: string;
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: string;
  ogImageUrl: string;
  twitterCard?: string;
  articlePublishedTime?: string;
  jsonLd?: unknown;
}

const {
  base,
  title,
  description,
  canonicalUrl,
  ogType = 'website',
  ogImageUrl,
  twitterCard = 'summary_large_image',
  articlePublishedTime,
  jsonLd,
} = Astro.props as Props;

const faviconIcoUrl = `${base}favicon.ico`;
const favicon16Url = `${base}favicon-16x16.png`;
const favicon32Url = `${base}favicon-32x32.png`;
const appleTouchIconUrl = `${base}apple-touch-icon.png`;
const manifestUrl = `${base}site.webmanifest`;

let siteOrigin = 'https://blog.whyself.cn';
try {
  siteOrigin = new URL(canonicalUrl).origin;
} catch {
  // Keep default origin for metadata fallbacks.
}

const siteRootUrl = new URL(base, siteOrigin).toString();
const profileImageUrl = new URL(`${base}images/profile-avatar.jpg`, siteOrigin).toString();
const siteLogoUrl = new URL(`${base}android-chrome-512x512.png`, siteOrigin).toString();

const pageJsonLdString = jsonLd ? (typeof jsonLd === 'string' ? jsonLd : JSON.stringify(jsonLd)) : null;
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteRootUrl}#website`,
      url: siteRootUrl,
      name: 'Blog | whyself',
      inLanguage: 'zh-CN',
      image: siteLogoUrl,
    },
    {
      '@type': 'Person',
      '@id': `${siteRootUrl}#person`,
      name: 'whyself',
      url: siteRootUrl,
      image: profileImageUrl,
    },
  ],
};
const siteJsonLdString = JSON.stringify(siteJsonLd);
---

<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<script is:inline>
  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }
</script>
<title>{title}</title>
<link href={canonicalUrl} rel="canonical" />
<meta content={description} name="description" />
<meta content={title} property="og:title" />
<meta content={description} property="og:description" />
<meta content={canonicalUrl} property="og:url" />
<meta content={ogType} property="og:type" />
<meta content="whyself" property="og:site_name" />
<meta content={ogImageUrl} property="og:image" />
{articlePublishedTime && <meta content={articlePublishedTime} property="article:published_time" />}
<meta content={twitterCard} name="twitter:card" />
<meta content={title} name="twitter:title" />
<meta content={description} name="twitter:description" />
<meta content={ogImageUrl} name="twitter:image" />
<meta content="#ffffff" name="theme-color" />
<meta content="#ffffff" name="msapplication-TileColor" />
<meta content={siteLogoUrl} name="msapplication-TileImage" />
{pageJsonLdString && <script is:inline type="application/ld+json" set:html={pageJsonLdString}></script>}
<script is:inline type="application/ld+json" set:html={siteJsonLdString}></script>
<link href={manifestUrl} rel="manifest" />
<link href={faviconIcoUrl} rel="shortcut icon" />
<link href={faviconIcoUrl} rel="icon" sizes="any" />
<link href={favicon32Url} rel="icon" sizes="32x32" type="image/png" />
<link href={favicon16Url} rel="icon" sizes="16x16" type="image/png" />
<link href={appleTouchIconUrl} rel="apple-touch-icon" sizes="180x180" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&family=Newsreader:ital,wght@0,400;0,700;1,400&family=Noto+Serif+SC:wght@400;500;700&display=swap" rel="stylesheet" />
<ThemeConfig />
