---
interface Props {
  selector?: string;
  offsetRatio?: number;
  behavior?: 'auto' | 'smooth';
  delayMs?: number;
  durationMs?: number;
}

const {
  selector = '[data-content-start]',
  offsetRatio = 0.22,
  behavior = 'smooth',
  delayMs = 120,
  durationMs = 760,
} = Astro.props as Props;

const script = `(() => {
  const contentStart = document.querySelector(${JSON.stringify(selector)});
  if (!contentStart) return;
  let hasStartedInitialScroll = false;

  const run = () => {
    if (hasStartedInitialScroll) return;

    const hash = window.location.hash ? decodeURIComponent(window.location.hash.slice(1)) : "";
    if (hash) {
      const hashTarget = document.getElementById(hash);
      if (hashTarget) {
        hasStartedInitialScroll = true;
        hashTarget.scrollIntoView({ block: "start", behavior: "auto" });
        return;
      }
    }

    const contentTop = contentStart.getBoundingClientRect().top + window.scrollY;
    const targetTop = Math.max(0, Math.round(contentTop - window.innerHeight * ${offsetRatio}));
    if (Math.abs(window.scrollY - targetTop) <= 2) {
      hasStartedInitialScroll = true;
      return;
    }
    const resolvedBehavior = ${JSON.stringify(behavior)};
    hasStartedInitialScroll = true;
    if (resolvedBehavior !== "smooth") {
      window.scrollTo({ top: targetTop, behavior: "auto" });
      return;
    }

    const startTop = window.scrollY;
    const delta = targetTop - startTop;
    const duration = Math.max(0, ${durationMs});
    if (Math.abs(delta) <= 2 || duration <= 0) {
      window.scrollTo({ top: targetTop, behavior: "auto" });
      return;
    }

    const startTs = performance.now();
    const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
    const tick = (now) => {
      const progress = Math.min(1, (now - startTs) / duration);
      const eased = easeInOutCubic(progress);
      window.scrollTo({ top: startTop + delta * eased, behavior: "auto" });
      if (progress < 1) window.requestAnimationFrame(tick);
    };
    window.requestAnimationFrame(tick);
  };

  const scheduleRun = (delay) => {
    window.setTimeout(() => {
      window.requestAnimationFrame(run);
    }, delay);
  };

  if ("scrollRestoration" in history) {
    history.scrollRestoration = "manual";
  }

  window.addEventListener("load", () => {
    scheduleRun(${delayMs});
  }, { once: true });

  window.addEventListener("pageshow", (event) => {
    if (event.persisted) scheduleRun(0);
  });
})();`;
---

<script is:inline set:html={script}></script>
