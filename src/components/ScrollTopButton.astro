---
import Icon from './Icon.astro';

const { threshold = 320, appearOffset = 180 } = Astro.props;
---

<button
  aria-label="Back to top"
  class="scroll-top-btn fixed left-12 bottom-12 z-40 inline-flex h-11 w-11 items-center justify-center rounded-full border border-outline-variant/40 bg-surface-container text-on-surface shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:bg-surface-container-high hover:shadow-lg dark:border-zinc-600/70 dark:bg-zinc-800/90 dark:text-zinc-100 dark:hover:bg-zinc-700/90"
  data-scroll-top
  data-threshold={threshold}
  data-appear-offset={appearOffset}
  type="button"
>
  <Icon class="w-5 h-5" name="arrow_upward" />
</button>

<style>
  .scroll-top-btn {
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
  }
  .scroll-top-btn.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const button = document.querySelector("[data-scroll-top]");
    if (!button) return;

    const threshold = Number(button.getAttribute("data-threshold") || "320");
    const appearOffset = Number(button.getAttribute("data-appear-offset") || "180");
    const initialOffsetRatio = 0.22;
    const scrollDuration = 680;
    let activeAnimation = 0;

    const getEntryScrollTop = () => {
      const contentStart = document.querySelector("[data-content-start]");
      if (!contentStart) return 0;
      const contentTop = contentStart.getBoundingClientRect().top + window.scrollY;
      return Math.max(0, Math.round(contentTop - window.innerHeight * initialOffsetRatio));
    };

    const syncVisibility = () => {
      const contentStart = document.querySelector("[data-content-start]");
      const showAt = contentStart ? getEntryScrollTop() + appearOffset : threshold;
      button.classList.toggle("is-visible", window.scrollY > showAt);
    };

    const animateScrollTo = (targetTop) => {
      const startTop = window.scrollY;
      const delta = targetTop - startTop;
      activeAnimation += 1;
      const animationId = activeAnimation;

      if (Math.abs(delta) <= 2) {
        window.scrollTo({ top: targetTop, behavior: "auto" });
        return;
      }

      const startTs = performance.now();
      const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
      const tick = (now) => {
        if (animationId !== activeAnimation) return;
        const progress = Math.min(1, (now - startTs) / scrollDuration);
        const eased = easeInOutCubic(progress);
        window.scrollTo({ top: startTop + delta * eased, behavior: "auto" });
        if (progress < 1) {
          window.requestAnimationFrame(tick);
          return;
        }
        window.scrollTo({ top: targetTop, behavior: "auto" });
      };
      window.requestAnimationFrame(tick);
    };

    button.addEventListener("click", () => {
      animateScrollTo(getEntryScrollTop());
    });

    window.addEventListener("scroll", syncVisibility, { passive: true });
    window.addEventListener("pageshow", syncVisibility);
    syncVisibility();
  })();
</script>
