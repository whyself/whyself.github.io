---
import { getCollection, render } from 'astro:content';
import "katex/dist/katex.min.css";
import HeroBanner from '../../components/HeroBanner.astro';
import Icon from '../../components/Icon.astro';
import InitialViewportScript from '../../components/InitialViewportScript.astro';
import PageHead from '../../components/PageHead.astro';
import ScrollTopButton from '../../components/ScrollTopButton.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import TopActions from '../../components/TopActions.astro';
import '../../styles/article-prose-base.css';
import { buildSearchItems, getPublishedPosts, sortPostsByDateDesc } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const base = import.meta.env.BASE_URL;
const allPosts = sortPostsByDateDesc(await getPublishedPosts());
const searchPosts = buildSearchItems(allPosts, base);
const currentPostIndex = allPosts.findIndex((entry) => entry.id === post.id);
const previousPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost = currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1 ? allPosts[currentPostIndex + 1] : null;
const title = post.data.title;
const authorAvatar = post.data.authorAvatar ?? `${base}images/profile-avatar.jpg`;
const headingTocItems = (headings ?? []).filter((h) => h.depth >= 1 && h.depth <= 6);
const fallbackTocItems = (post.data.toc ?? []).map((item) => ({
  depth: item.depth ?? 2,
  slug: item.id,
  text: item.label,
}));
const tocItems = headingTocItems.length > 0 ? headingTocItems : fallbackTocItems;
const tocBaseDepth = tocItems.reduce((minDepth, item) => Math.min(minDepth, item.depth), 6);
const getTocItemClass = (depth: number) => {
  const level = Math.max(0, depth - tocBaseDepth);
  const levels = [
    "text-[14px] pl-4 font-medium",
    "text-[13px] pl-7 font-normal",
    "text-[12px] pl-10 font-normal",
    "text-[12px] pl-12 font-normal",
    "text-[12px] pl-14 font-normal",
    "text-[12px] pl-16 font-normal",
  ];
  return levels[Math.min(level, levels.length - 1)];
};
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const seoTitle = `${title} | whyself`;
const seoDescription = post.data.excerpt;
const canonicalUrl = new URL(`${base}posts/${post.id}/`, siteOrigin).toString();
const rawOgImage = post.data.thumbnail ?? `${base}images/hero/blog-hero-light-1920.webp`;
const ogImageUrl = /^https?:\/\//.test(rawOgImage) ? rawOgImage : new URL(rawOgImage, siteOrigin).toString();
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: seoDescription,
  url: canonicalUrl,
  image: [ogImageUrl],
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Person",
    name: "whyself",
    image: {
      "@type": "ImageObject",
      url: new URL(`${base}images/profile-avatar.jpg`, siteOrigin).toString(),
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
};
---

<!DOCTYPE html>
<html class="light" lang="en"><head>
<PageHead
  base={base}
  title={seoTitle}
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImageUrl={ogImageUrl}
  twitterCard="summary_large_image"
  articlePublishedTime={post.data.publishDate.toISOString()}
  jsonLd={articleJsonLd}
/>
<style>
  .post-content-start {
    --article-top-gap: 3rem;
    margin-top: var(--article-top-gap);
  }
  .article-body {
    --body-size: 1rem;
    --body-line: 1.72;
    --h1-size: clamp(1.5rem, 2.25vw, 1.86rem);
    --h2-size: clamp(1.28rem, 1.85vw, 1.54rem);
    --h3-size: clamp(1.14rem, 1.45vw, 1.3rem);
    --h4-size: clamp(1.04rem, 1.18vw, 1.16rem);
    color: #1f2937;
    font-family: Newsreader, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Serif SC", serif;
    font-size: var(--body-size);
    line-height: var(--body-line);
    min-width: 0;
    overflow-x: hidden;
  }
  .article-body > * {
    min-width: 0;
    max-width: 100%;
  }
  .article-body :global(*) {
    box-sizing: border-box;
    max-width: 100%;
  }
  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3),
  .article-body :global(h4) {
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue", Arial, sans-serif;
    color: #1f2329;
    letter-spacing: -0.015em;
    font-weight: 700;
    line-height: 1.32;
    margin-top: 1.3em !important;
    margin-bottom: 0.45em !important;
  }
  .article-body :global(h1) {
    font-size: var(--h1-size);
  }
  .article-body :global(h2) {
    font-size: var(--h2-size);
  }
  .article-body :global(h3) {
    font-size: var(--h3-size);
  }
  .article-body :global(h4) {
    font-size: var(--h4-size);
  }
  .article-body :global(p),
  .article-body :global(li),
  .article-body :global(td) {
    font-size: var(--body-size);
    line-height: var(--body-line);
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .article-body :global(blockquote) {
    font-size: 0.98rem;
    line-height: var(--body-line);
    color: #4b5563;
    border-left: 3px solid #d0d7de;
    padding-left: 0.9em;
    margin: 0.95em 0 !important;
  }
  .article-body :global(blockquote p) {
    font-size: inherit;
    line-height: inherit;
    margin: 0;
  }
  .article-body :global(p),
  .article-body :global(li),
  .article-body :global(blockquote),
  .article-body :global(td) {
    text-size-adjust: 100%;
    -webkit-text-size-adjust: 100%;
  }
  .article-body :global(p) {
    margin: 0.8em 0;
  }
  .article-body :global(p + h2),
  .article-body :global(p + h3),
  .article-body :global(p + h4) {
    margin-top: 1.05em !important;
  }
  .article-body :global(pre) {
    background: #f6f8fa;
    border: 1px solid #e5e7eb;
    border-radius: 0.65rem;
    padding: 1rem 1.1rem;
    margin: 1.25rem 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    max-width: 100%;
    width: 100%;
    overflow-x: auto !important;
    box-sizing: border-box;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(pre.astro-code) {
    margin-left: 0 !important;
    margin-right: 0 !important;
  }
  .article-body :global(.astro-code) {
    max-width: 100%;
    overflow-x: auto !important;
    box-sizing: border-box;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.95rem;
    line-height: 1.65;
    color: #1f2937;
    background: transparent;
    border: none;
    border-radius: 0;
    display: inline-block;
    padding: 0;
    overflow-x: visible;
    max-width: 100%;
    box-sizing: border-box;
    min-width: 100%;
    box-shadow: none;
  }
  .article-body :global(:not(pre) > code) {
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .article-body :global(.code-block-shell) {
    border: 1px solid #e5e7eb;
    border-radius: 0.7rem;
    background: #f8f9fb;
    overflow-x: auto;
    overflow-y: hidden;
    margin: 1.5rem 0;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.02);
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
  }
  .article-body :global(.code-block-head) {
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.75rem 0 0.85rem;
    background: #f2f4f7;
    border-bottom: 1px solid #e5e7eb;
  }
  .article-body :global(.code-block-lang) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.72rem;
    line-height: 1;
    color: #6b7280;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }
  .article-body :global(.code-block-copy) {
    width: 1.7rem;
    height: 1.7rem;
    border: 1px solid #d0d7de;
    background: #ffffff;
    color: #24292f;
    border-radius: 0.35rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .article-body :global(.code-block-copy:hover) {
    background: #f3f4f6;
  }
  .article-body :global(.code-block-shell pre) {
    margin: 0;
    border: none;
    border-radius: 0;
    box-shadow: none;
    background: #f8f9fb;
    padding: 0.9rem 1rem 1rem;
    max-width: 100%;
    overflow-x: auto !important;
    box-sizing: border-box;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(table) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(.katex-display) {
    display: block;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(.katex-display > .katex) {
    white-space: nowrap;
  }
  .article-body :global(img),
  .article-body :global(video),
  .article-body :global(iframe),
  .article-body :global(svg),
  .article-body :global(canvas) {
    max-width: 100%;
    height: auto;
  }
  .article-body :global(.post-media) {
    --media-max: 760px;
    max-width: min(100%, var(--media-max));
    margin: 1.2rem auto;
  }
  .article-body :global(.post-media--wide) {
    --media-max: 920px;
  }
  .article-body :global(.post-media--narrow) {
    --media-max: 620px;
  }
  .article-body :global(.post-media--inline),
  .article-body :global(.post-media--float) {
    --media-max: 320px;
    width: min(38%, var(--media-max));
    margin-top: 0.35rem;
    margin-bottom: 0.9rem;
  }
  .article-body :global(.post-media--inline-right),
  .article-body :global(.post-media--float-right) {
    float: right;
    margin-right: 0;
    margin-left: 1.6rem;
  }
  .article-body :global(.post-media--inline-left),
  .article-body :global(.post-media--float-left) {
    float: left;
    margin-left: 0;
    margin-right: 1.6rem;
  }
  .article-body :global(.post-media--center-narrow) {
    --media-max: 620px;
    max-width: min(92%, var(--media-max));
    margin: 1.2rem auto;
  }
  .article-body :global(.post-media-clear) {
    clear: both;
    height: 0;
  }
  .article-body :global(.post-media-pair) {
    --pair-media-col: minmax(220px, 40%);
    --pair-gap: 1.6rem;
    display: grid;
    grid-template-columns: var(--pair-media-col) minmax(0, 1fr);
    gap: var(--pair-gap);
    align-items: end;
    max-width: min(100%, 920px);
    margin: 1.2rem auto;
  }
  .article-body :global(.post-media-pair--right) {
    grid-template-columns: minmax(0, 1fr) var(--pair-media-col);
  }
  .article-body :global(.post-media-pair .post-media) {
    max-width: none;
    margin: 0;
  }
  .article-body :global(.post-media-pair__text) {
    min-width: 0;
  }
  .article-body :global(.post-media-pair__text > :first-child) {
    margin-top: 0;
  }
  .article-body :global(.post-media-pair__text > :last-child) {
    margin-bottom: 0;
  }
  .article-body :global(.post-media-pair--balanced) {
    --pair-media-col: minmax(300px, 50%);
    --pair-gap: 2.4rem;
    align-items: start;
  }
  .article-body :global(.post-media-pair--balanced .post-media) {
    display: block;
    height: auto;
  }
  .article-body :global(.post-media-pair--balanced .post-media img) {
    aspect-ratio: 16 / 10;
    width: 100%;
    height: auto;
    object-fit: cover;
  }
  .article-body :global(.post-media-pair--balanced .post-media-pair__text) {
    display: block;
    height: auto;
  }
  .article-body :global(.post-media img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }
  .article-body :global(.post-media figcaption) {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.85rem;
    line-height: 1.5;
    color: #6b7280;
  }
  .article-body :global(.post-media-grid) {
    --media-cols: 2;
    --media-max: 920px;
    display: grid;
    grid-template-columns: repeat(var(--media-cols), minmax(0, 1fr));
    gap: 0.45rem;
    max-width: min(100%, var(--media-max));
    margin: 1.2rem auto;
  }
  .article-body :global(.post-media-grid--2) {
    --media-cols: 2;
  }
  .article-body :global(.post-media-grid--3) {
    --media-cols: 3;
  }
  .article-body :global(.post-media-grid img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }
  .article-body :global(img[data-previewable="true"]) {
    cursor: zoom-in;
  }
  :global(.image-lightbox) {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.52);
    backdrop-filter: none;
  }
  :global(.image-lightbox.is-open) {
    display: flex;
  }
  :global(.image-lightbox__stage) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border-radius: 0;
    padding: 0;
  }
  :global(.image-lightbox__image) {
    display: block;
    max-width: min(88vw, 1400px);
    max-height: 86vh;
    width: auto;
    height: auto;
    border-radius: 0;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
    opacity: 1 !important;
    filter: none !important;
    mix-blend-mode: normal;
    transition: none;
  }
  html.dark body {
    background: #1a1a1a;
    color: rgba(255, 255, 255, 0.87);
  }
  html.dark .article-body {
    color: #d7e2ee;
  }
  html.dark .article-body :global(pre) {
    border-color: rgba(84, 84, 84, 0.65);
    box-shadow: none;
  }
  html.dark .article-body :global(.code-block-shell) {
    border-color: rgba(84, 84, 84, 0.65);
    background: #242424;
  }
  html.dark .article-body :global(.code-block-head) {
    background: #2f2f2f;
    border-bottom-color: rgba(84, 84, 84, 0.65);
  }
  html.dark .article-body :global(.code-block-lang) {
    color: rgba(235, 235, 235, 0.48);
  }
  html.dark .article-body :global(.code-block-copy) {
    background: #363636;
    color: rgba(235, 235, 235, 0.68);
    border-color: rgba(84, 84, 84, 0.78);
  }
  html.dark .article-body :global(.code-block-copy:hover) {
    background: #3f3f3f;
  }
  html.dark .article-body :global(.post-media figcaption) {
    color: rgba(235, 235, 235, 0.48);
  }
  html {
    scroll-behavior: smooth;
  }
  @media (max-width: 768px) {
    html, body {
      max-width: 100%;
      overflow-x: hidden;
    }
    .article-body :global(.post-media-grid) {
      gap: 0.35rem;
    }
    .article-body :global(.post-media--inline),
    .article-body :global(.post-media--float) {
      float: none;
      width: auto;
      max-width: min(100%, 620px);
      margin: 1.1rem auto;
    }
    .article-body :global(.post-media-pair),
    .article-body :global(.post-media-pair--right) {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      align-items: start;
      max-width: min(100%, 620px);
    }
    .article-body :global(.post-media-pair--balanced .post-media-pair__text) {
      display: block;
      height: auto;
    }
    .article-body :global(.post-media-grid--3) {
      --media-cols: 2;
    }
    .article-body :global(pre.astro-code) {
      width: min(100%, calc(100vw - 3rem)) !important;
      max-width: min(100%, calc(100vw - 3rem)) !important;
    }
    .article-body :global(pre.astro-code code) {
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
      display: block;
      width: 100%;
      min-width: 0;
    }
  }
  @media (max-width: 560px) {
    .article-body :global(.post-media-grid) {
      --media-cols: 1;
    }
  }
  @media (max-width: 1023px) {
    .post-content-start {
      --article-top-gap: 2rem;
    }
  }
</style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
<TopActions searchItems={searchPosts} />
<main class="w-full mb-8">
  <HeroBanner alt="Hero Header Image" base={base} />
  <div class="post-content-start max-w-screen-2xl mx-auto px-6 lg:px-12 relative z-10" data-content-start>
    <nav class="mb-12">
      <a class="inline-flex items-center gap-2.5 font-headline font-bold text-sm uppercase tracking-[0.12em] text-primary hover:opacity-60 transition-opacity" href={base}>
        <Icon class="w-5 h-5" name="arrow_back" />
        back to the list
      </a>
    </nav>
    <div class="flex flex-col lg:flex-row lg:items-start gap-8 xl:gap-10">
      <article class="flex-1 min-w-0 max-w-4xl mx-auto lg:mx-0 bg-transparent p-0 md:p-0 shadow-none overflow-x-hidden">
        <header class="mb-10">
          <h1 class="font-headline text-[1.75rem] md:text-[2.15rem] font-bold tracking-tight text-primary leading-tight mb-4 break-words">{title}</h1>
          <div class="flex flex-wrap items-start gap-3 mb-5 max-w-full">
            <img alt="Author" class="w-6 h-6 rounded-full object-cover" decoding="async" height="24" loading="lazy" src={authorAvatar} width="24"/>
            <div class="flex min-w-0 max-w-full flex-wrap items-center gap-2">
              <span class="font-headline text-[11px] font-semibold tracking-wide text-primary break-words">Written by {post.data.author}</span>
              <span class="text-outline-variant">|</span>
              <span class="font-headline text-[11px] tracking-wide text-on-surface-variant break-words">{post.data.articleDate ?? post.data.listDate}</span>
              {post.data.tags.map((tag) => (
                <span class="px-3 py-1 bg-surface-container-high text-[10px] font-headline font-bold uppercase tracking-widest rounded-full max-w-full break-words">{tag}</span>
              ))}
            </div>
          </div>
          {post.data.subtitle && <p class="font-body text-[1.02rem] text-on-surface-variant leading-relaxed">{post.data.subtitle}</p>}
        </header>
        <div class="article-body text-on-surface">
          <Content />
        </div>
        {(previousPost || nextPost) && (
          <nav class="mt-12 flex flex-col gap-3 border-t border-outline-variant/20 pt-6">
            {previousPost ? (
              <a class="group inline-flex min-w-0 max-w-full items-center gap-1.5 text-sm font-headline text-on-surface-variant hover:text-primary transition-colors self-start" href={`${base}posts/${previousPost.id}/`}>
                <Icon class="w-[18px] h-[18px]" name="arrow_back" />
                <span class="truncate">上一篇: {previousPost.data.listTitle ?? previousPost.data.title}</span>
              </a>
            ) : null}
            {nextPost ? (
              <a class="group inline-flex min-w-0 max-w-full items-center justify-end gap-1.5 text-right text-sm font-headline text-on-surface-variant hover:text-primary transition-colors self-end" href={`${base}posts/${nextPost.id}/`}>
                <span class="truncate">下一篇: {nextPost.data.listTitle ?? nextPost.data.title}</span>
                <Icon class="w-[18px] h-[18px]" name="arrow_forward" />
              </a>
            ) : null}
          </nav>
        )}
      </article>
      <aside class="hidden lg:block w-72 xl:w-80 pt-2 self-start lg:sticky lg:h-fit" style="top: var(--article-top-gap);">
        <div class="space-y-8">
          {tocItems.length > 0 && (
            <div>
              <h4 class="font-headline text-[16px] font-bold tracking-normal text-primary mb-4">Outline</h4>
              <nav class="space-y-2.5">
                {tocItems.map((item) => (
                  <a
                    class={`block font-headline ${getTocItemClass(item.depth)} tracking-normal text-on-surface-variant hover:text-primary transition-colors border-l-2 border-transparent leading-[1.42]`}
                    data-toc-link
                    data-toc-slug={item.slug}
                    href={`#${item.slug}`}
                  >
                    {item.text}
                  </a>
                ))}
              </nav>
            </div>
          )}
          <div class="pt-8 border-t border-outline-variant/20">
            <h4 class="font-headline text-[10px] font-black uppercase tracking-[0.2em] text-primary mb-4">Share</h4>
            <div class="flex gap-2">
              <button aria-label="Copy link" class="w-8 h-8 flex items-center justify-center bg-surface-container-high hover:bg-primary hover:text-white transition-all" data-share-copy-link type="button">
                <span data-share-copy-icon><Icon class="w-4 h-4" name="link" /></span>
              </button>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</main>
<ScrollTopButton />
<SiteFooter />
<script is:inline>
  (() => {
    const shareCopyButton = document.querySelector("[data-share-copy-link]");
    const shareCopyIcon = document.querySelector("[data-share-copy-icon]");

    const iconSvg = (name) => {
      if (name === "content_copy") {
        return '<svg aria-hidden="true" class="w-[14px] h-[14px]" fill="none" viewBox="0 0 24 24"><rect height="12" rx="1.8" stroke="currentColor" stroke-width="1.8" width="10.5" x="8.2" y="7.2"></rect><path d="M5.3 15.3H4.8a1.8 1.8 0 0 1-1.8-1.8V4.8A1.8 1.8 0 0 1 4.8 3h8.7a1.8 1.8 0 0 1 1.8 1.8v.5" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path></svg>';
      }
      if (name === "check") {
        return '<svg aria-hidden="true" class="w-[14px] h-[14px]" fill="none" viewBox="0 0 24 24"><path d="m5 12 4.2 4.2L19 6.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path></svg>';
      }
      if (name === "error") {
        return '<svg aria-hidden="true" class="w-[14px] h-[14px]" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"></circle><path d="M12 7.5v5.3M12 16h.01" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path></svg>';
      }
      if (name === "link") {
        return '<svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24"><path d="m10 14 4-4M8.5 16.5l-1.6 1.6a3.3 3.3 0 1 1-4.7-4.7L5 10.6M15.5 7.5l1.6-1.6a3.3 3.3 0 1 1 4.7 4.7L19 13.4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"></path></svg>';
      }
      return "";
    };

    const enhanceImageTransition = (img) => {
      if (!(img instanceof HTMLImageElement)) return;
      const src = img.getAttribute("src") || "";
      if (!src) return;

      img.loading = "lazy";
      img.decoding = "async";

      const onLoaded = () => {
        const naturalW = img.naturalWidth || 0;
        const naturalH = img.naturalHeight || 0;
        if (naturalW > 0 && naturalH > 0) {
          if (!img.getAttribute("width")) img.setAttribute("width", String(naturalW));
          if (!img.getAttribute("height")) img.setAttribute("height", String(naturalH));
        }
      };

      if (img.complete && img.naturalWidth > 0) {
        onLoaded();
      } else {
        img.addEventListener("load", onLoaded, { once: true });
      }
    };

    const enhanceArticleImages = () => {
      const articleImages = Array.from(document.querySelectorAll(".article-body img"));
      articleImages.forEach((node) => {
        enhanceImageTransition(node);
        node.setAttribute("data-previewable", "true");
      });
    };
    enhanceArticleImages();

    const lightbox = document.createElement("div");
    lightbox.className = "image-lightbox";
    lightbox.setAttribute("aria-hidden", "true");
    const lightboxStage = document.createElement("div");
    lightboxStage.className = "image-lightbox__stage";
    const lightboxImage = document.createElement("img");
    lightboxImage.className = "image-lightbox__image";
    lightboxImage.alt = "";
    lightboxStage.appendChild(lightboxImage);
    lightbox.appendChild(lightboxStage);
    document.body.appendChild(lightbox);

    const openImagePreview = (img) => {
      if (!(img instanceof HTMLImageElement)) return;
      const src = img.currentSrc || img.src;
      if (!src) return;
      lightboxImage.src = src;
      lightboxImage.alt = img.alt || "";
      lightbox.classList.add("is-open");
      lightbox.setAttribute("aria-hidden", "false");
    };

    const closeImagePreview = () => {
      lightbox.classList.remove("is-open");
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.removeAttribute("src");
      lightboxImage.alt = "";
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const candidate =
        target instanceof HTMLImageElement ? target : target.closest("img");
      if (!(candidate instanceof HTMLImageElement)) return;
      if (candidate.getAttribute("data-previewable") !== "true") return;
      if (!candidate.closest(".article-body")) return;
      openImagePreview(candidate);
    });

    lightbox.addEventListener("click", (event) => {
      if (!(event.target instanceof Element)) return;
      if (event.target === lightboxImage || lightboxImage.contains(event.target)) return;
      closeImagePreview();
    });

    const blocks = Array.from(document.querySelectorAll(".article-body pre"));
    blocks.forEach((pre) => {
      if (pre.parentElement?.classList.contains("code-block-shell")) return;
      const code = pre.querySelector("code");
      if (!code) return;

      const className = code.className || "";
      const matched = className.match(/language-([a-zA-Z0-9_-]+)/);
      const rawLang = (pre.getAttribute("data-language") || code.getAttribute("data-language") || matched?.[1] || "").toLowerCase();
      const lang = (rawLang === "text" || rawLang === "txt" || rawLang === "plaintext" || rawLang === "") ? "plain" : rawLang;
      const rawText = code.textContent || "";

      const shell = document.createElement("div");
      shell.className = "code-block-shell";

      const head = document.createElement("div");
      head.className = "code-block-head";

      const langNode = document.createElement("span");
      langNode.className = "code-block-lang";
      langNode.textContent = lang;

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "code-block-copy";
      copyBtn.innerHTML = iconSvg("content_copy");
      copyBtn.title = "Copy code";
      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(rawText);
          copyBtn.innerHTML = iconSvg("check");
          setTimeout(() => { copyBtn.innerHTML = iconSvg("content_copy"); }, 1200);
        } catch {
          copyBtn.innerHTML = iconSvg("error");
          setTimeout(() => { copyBtn.innerHTML = iconSvg("content_copy"); }, 1200);
        }
      });

      head.appendChild(langNode);
      head.appendChild(copyBtn);
      shell.appendChild(head);

      pre.parentNode?.insertBefore(shell, pre);
      shell.appendChild(pre);
    });

    shareCopyButton?.addEventListener("click", async () => {
      const currentUrl = window.location.href;

      const setIcon = (nextIcon) => {
        if (shareCopyIcon) shareCopyIcon.innerHTML = iconSvg(nextIcon);
      };

      const resetIconLater = () => {
        window.setTimeout(() => setIcon("link"), 1200);
      };

      try {
        if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable");
        await navigator.clipboard.writeText(currentUrl);
        setIcon("check");
        resetIconLater();
      } catch {
        setIcon("error");
        resetIconLater();
      }
    });

    const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
    if (tocLinks.length > 0) {
      const tocMap = new Map();
      tocLinks.forEach((link) => {
        const slug = link.getAttribute("data-toc-slug");
        if (!slug) return;
        const target = document.getElementById(slug);
        if (!target) return;
        tocMap.set(target, link);
      });

      const setActiveTocLink = (activeLink) => {
        tocLinks.forEach((link) => {
          const isActive = link === activeLink;
          link.classList.toggle("text-primary", isActive);
          link.classList.toggle("border-primary", isActive);
          link.classList.toggle("font-semibold", isActive);
          link.classList.toggle("text-on-surface-variant", !isActive);
          link.classList.toggle("border-transparent", !isActive);
        });
      };

      const headingEntries = Array.from(tocMap.keys());

      const pickActiveHeadingByVisibility = () => {
        const current =
          headingEntries.find((heading) => heading.getBoundingClientRect().bottom > 0) ??
          headingEntries[headingEntries.length - 1] ??
          null;
        setActiveTocLink(current ? tocMap.get(current) : null);
      };

      pickActiveHeadingByVisibility();

      const observer = new IntersectionObserver(
        () => {
          pickActiveHeadingByVisibility();
        },
        {
          root: null,
          rootMargin: "0px",
          threshold: [0, 0.01, 1],
        },
      );

      headingEntries.forEach((heading) => observer.observe(heading));
      window.addEventListener("scroll", pickActiveHeadingByVisibility, { passive: true });
      window.addEventListener("resize", pickActiveHeadingByVisibility);

      window.addEventListener("hashchange", () => {
        window.requestAnimationFrame(pickActiveHeadingByVisibility);
      });
    }

  })();
</script>
<InitialViewportScript />
</body></html>

