---
import HeroBanner from '../components/HeroBanner.astro';
import InitialViewportScript from '../components/InitialViewportScript.astro';
import ProfileSidebar from '../components/ProfileSidebar.astro';
import ScrollTopButton from '../components/ScrollTopButton.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TopActions from '../components/TopActions.astro';
import PageHead from '../components/PageHead.astro';
import type { SearchItem } from '../utils/posts';
import '../styles/article-prose-base.css';

interface Props {
  base: string;
  searchItems: SearchItem[];
  seoTitle: string;
  seoDescription: string;
  canonicalUrl: string;
  ogImageUrl: string;
  heroTitle: string;
  activeNav: 'about' | 'bio';
  sectionTitle: string;
  subtitle?: string;
}

const {
  base,
  searchItems,
  seoTitle,
  seoDescription,
  canonicalUrl,
  ogImageUrl,
  heroTitle,
  activeNav,
  sectionTitle,
  subtitle,
} = Astro.props as Props;
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <PageHead
    base={base}
    title={seoTitle}
    description={seoDescription}
    canonicalUrl={canonicalUrl}
    ogType="profile"
    ogImageUrl={ogImageUrl}
    twitterCard="summary"
  />
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-surface text-on-surface selection:bg-primary-container selection:text-white">
  <TopActions searchItems={searchItems} />
  <HeroBanner base={base} title={heroTitle} />
  <main class="max-w-screen-2xl mx-auto flex flex-col lg:flex-row min-h-screen lg:py-12" data-content-start>
    <ProfileSidebar active={activeNav} />
    <section class="min-w-0 flex-1 lg:-ml-16 lg:pl-0 lg:pr-0 py-4 md:py-12 lg:py-0">
      <article class="w-full mx-0 px-6 md:px-8 lg:pl-14 lg:pr-10 py-8 md:py-10 bg-surface-container-lowest border border-surface-container-high rounded-sm">
        <h1 class="font-headline font-black uppercase text-sm tracking-[0.2em] text-outline">{sectionTitle}</h1>
        {subtitle && <p class="mt-4 text-lg text-on-surface-variant italic">{subtitle}</p>}
        <div class="mt-10 article-body">
          <slot />
        </div>
      </article>
    </section>
    <aside class="w-full lg:w-[24rem] xl:w-[26rem] p-6 lg:ml-8 lg:pl-6 lg:pr-4 lg:pt-10 lg:pb-8 lg:sticky lg:top-11 lg:h-fit"></aside>
  </main>
  <SiteFooter />
  <ScrollTopButton />
  <InitialViewportScript />
</body>
</html>
